{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlacementLedger",
  "type": "object",
  "required": ["placements"],
  "properties": {
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["device_id", "pose", "confidence"],
        "properties": {
          "device_id": {"type": "string"},
          "pose": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "z": {"type": "number"}
            }
          },
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
