{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-contract-version": "1.0.0",
  "title": "LayoutSolution",
  "type": "object",
  "required": ["solution_id", "problem_id", "status", "placements"],
  "properties": {
    "solution_id": {"type": "string"},
    "problem_id": {"type": "string"},
    "status": {"type": "string", "enum": ["feasible", "infeasible"]},
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["device_id", "pose"],
        "properties": {
          "device_id": {"type": "string"},
          "pose": {
            "type": "object",
            "required": ["x_m", "y_m", "z_m", "yaw_deg"],
            "properties": {
              "x_m": {"type": "number"},
              "y_m": {"type": "number"},
              "z_m": {"type": "number"},
              "yaw_deg": {"type": "number"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "objective_score": {"type": "number"},
    "rejection_reasons": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
